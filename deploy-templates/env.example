# EasyStock — Server production (.env on deploy server)
# cp env.example .env

NODE_ENV=production
DEPLOYMENT_MODE=server
SERVE_FRONTEND=true

HOST=0.0.0.0
PORT=4000

DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=easystock
DB_USER=easystock
DB_PASSWORD=change-me

JWT_SECRET=change-me-long-random
SESSION_SECRET=change-me-long-random
FRONTEND_URL=https://yourdomain.com

SUPERADMIN_EMAILS=admin@example.com
LICENSE_SIGNING_SECRET=change-me-long-random-secret
LICENSE_PRODUCT_ID=easystock-accountant

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Optional OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback
