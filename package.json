{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "build": "next build",
    "build:web:server": "NEXT_PUBLIC_DEPLOYMENT_MODE=server NEXT_PUBLIC_ALLOWED_STORAGE_TYPES=online next build",
    "check:desktop-hygiene": "node scripts/check-desktop-hygiene.mjs",
    "generate:license-gates": "node scripts/generate-license-gates.mjs",
    "build:web:electron": "node scripts/generate-license-gates.mjs && NEXT_PUBLIC_IS_ELECTRON=true NEXT_PUBLIC_API_URL=https://hesab.amoza.ir NEXT_PUBLIC_ALLOWED_STORAGE_TYPES=sqlite,online NEXT_PUBLIC_LOCAL_API_URL=http://127.0.0.1:43031 next build && node scripts/obfuscate-next-electron.mjs",
    "obfuscate:next:electron": "node scripts/obfuscate-next-electron.mjs",
    "build:backend": "node scripts/build-backend.mjs",
    "build:electron:main": "node scripts/build-electron-main.mjs",
    "generate:electron:icons": "python3 scripts/generate-electron-icons.py",
    "rebuild:electron:natives": "node scripts/rebuild-electron-natives.mjs",
    "build:electron:assets": "npm run generate:electron:icons && npm run build:backend && npm run build:web:electron && npm run build:electron:main && npm run rebuild:electron:natives",
    "dist:linux": "npm run build:electron:assets && electron-builder --linux AppImage",
    "dist:linux:pack": "electron-builder --linux AppImage",
    "dist:win": "npm run build:electron:assets && electron-builder --win portable",
    "dist:win:pack": "electron-builder --win portable",
    "dist:all": "echo 'Run dist:linux on Linux and dist:win on Windows separately — native modules are platform-specific.' && exit 1",
    "start": "NODE_ENV=production node server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.8",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.475.0",
    "next": "15.3.3",
    "next-themes": "^0.3.0",
    "patch-package": "^8.0.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-multi-date-picker": "^4.5.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@electron/rebuild": "^3.7.2",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.12",
    "javascript-obfuscator": "^4.2.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "packageManager": "npm@10.8.2"
}
