# Frontend (build-time, NEXT_PUBLIC_* are embedded at build)
NEXT_PUBLIC_LOCAL_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=https://api.easystock.com
NEXT_PUBLIC_ALLOWED_STORAGE_TYPES=sqlite,online
NEXT_PUBLIC_IS_ELECTRON=false
NEXT_PUBLIC_DEV_MODE_USER_UID=

# Server deploy example:
# NEXT_PUBLIC_ALLOWED_STORAGE_TYPES=online
# NEXT_PUBLIC_DEPLOYMENT_MODE=server
# DEPLOYMENT_MODE=server
# SUPERADMIN_EMAILS=php.modern@gmail.com
# LICENSE_SIGNING_SECRET=

# Electron build example (.env.electron):
# NEXT_PUBLIC_IS_ELECTRON=true
# NEXT_PUBLIC_ALLOWED_STORAGE_TYPES=sqlite,online
# NEXT_PUBLIC_LOCAL_API_URL=http://127.0.0.1:43031

# Backend
PORT=4000
HOST=localhost
DB_TYPE=sqlite
SQLITE_PATH=./database.sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=easystock
DB_USER=root
DB_PASSWORD=
JWT_SECRET=
SESSION_SECRET=
FRONTEND_URL=http://localhost:9002
DEPLOYMENT_MODE=desktop

# Superadmin (server deployment)
SUPERADMIN_EMAILS=

# License signing (server deployment only — never ship to desktop)
LICENSE_SIGNING_SECRET=

# License (Electron local backend only)
LICENSE_ENABLED=false
LICENSE_SERVER_URL=https://license.yourdomain.com/api/v1
LICENSE_PRODUCT_ID=easystock-accountant
MACHINE_ID=
